@SlotStyle = (
  Default: (Background: #3a7bd5),
  Hovered: (Background: #4a8be5),
  Pressed: (Background: #2a6bc5)
);

@SlotLabelStyle = (
  FontSize: 11,
  TextColor: #ffffff,
  RenderBold: true,
  HorizontalAlignment: Center,
  VerticalAlignment: Center
);

@CloseButtonStyle = TextButtonStyle(
  Default: (Background: #2b3542, LabelStyle: (FontSize: 13, TextColor: #96a9be, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #3b4552, LabelStyle: (FontSize: 13, TextColor: #b6c9de, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #1b2532, LabelStyle: (FontSize: 13, TextColor: #96a9be, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
);

Group {
  Anchor: (Width: 420, Height: 420);
  Background: #141c26(0.98);
  LayoutMode: Top;
  Padding: (Full: 20);

  Label #Title {
    Text: "Menu";
    Anchor: (Height: 45);
    Style: (
      FontSize: 24,
      TextColor: #ffffff,
      HorizontalAlignment: Center,
      RenderBold: true
    );
  }

  Group {
    Anchor: (Height: 1);
    Background: #2b3542;
  }

  Group { Anchor: (Height: 16); }

  Group #Row0 {
    LayoutMode: Center;
    Anchor: (Height: 70);

    Button #Slot0 {
      Anchor: (Width: 110, Height: 62);
      Style: @SlotStyle;
      LayoutMode: Top;
      Padding: (Full: 4);

      ItemIcon #Slot0Icon {
        Anchor: (Width: 32, Height: 32);
      }

      Label #Slot0Text {
        Text: "";
        Anchor: (Height: 20);
        Style: @SlotLabelStyle;
      }
    }

    Group { Anchor: (Width: 10); }

    Button #Slot1 {
      Anchor: (Width: 110, Height: 62);
      Style: @SlotStyle;
      LayoutMode: Top;
      Padding: (Full: 4);

      ItemIcon #Slot1Icon {
        Anchor: (Width: 32, Height: 32);
      }

      Label #Slot1Text {
        Text: "";
        Anchor: (Height: 20);
        Style: @SlotLabelStyle;
      }
    }

    Group { Anchor: (Width: 10); }

    Button #Slot2 {
      Anchor: (Width: 110, Height: 62);
      Style: @SlotStyle;
      LayoutMode: Top;
      Padding: (Full: 4);

      ItemIcon #Slot2Icon {
        Anchor: (Width: 32, Height: 32);
      }

      Label #Slot2Text {
        Text: "";
        Anchor: (Height: 20);
        Style: @SlotLabelStyle;
      }
    }
  }

  Group { Anchor: (Height: 8); }

  Group #Row1 {
    LayoutMode: Center;
    Anchor: (Height: 70);

    Button #Slot3 {
      Anchor: (Width: 110, Height: 62);
      Style: @SlotStyle;
      LayoutMode: Top;
      Padding: (Full: 4);

      ItemIcon #Slot3Icon {
        Anchor: (Width: 32, Height: 32);
      }

      Label #Slot3Text {
        Text: "";
        Anchor: (Height: 20);
        Style: @SlotLabelStyle;
      }
    }

    Group { Anchor: (Width: 10); }

    Button #Slot4 {
      Anchor: (Width: 110, Height: 62);
      Style: @SlotStyle;
      LayoutMode: Top;
      Padding: (Full: 4);

      ItemIcon #Slot4Icon {
        Anchor: (Width: 32, Height: 32);
      }

      Label #Slot4Text {
        Text: "";
        Anchor: (Height: 20);
        Style: @SlotLabelStyle;
      }
    }

    Group { Anchor: (Width: 10); }

    Button #Slot5 {
      Anchor: (Width: 110, Height: 62);
      Style: @SlotStyle;
      LayoutMode: Top;
      Padding: (Full: 4);

      ItemIcon #Slot5Icon {
        Anchor: (Width: 32, Height: 32);
      }

      Label #Slot5Text {
        Text: "";
        Anchor: (Height: 20);
        Style: @SlotLabelStyle;
      }
    }
  }

  Group { Anchor: (Height: 8); }

  Group #Row2 {
    LayoutMode: Center;
    Anchor: (Height: 70);

    Button #Slot6 {
      Anchor: (Width: 110, Height: 62);
      Style: @SlotStyle;
      LayoutMode: Top;
      Padding: (Full: 4);

      ItemIcon #Slot6Icon {
        Anchor: (Width: 32, Height: 32);
      }

      Label #Slot6Text {
        Text: "";
        Anchor: (Height: 20);
        Style: @SlotLabelStyle;
      }
    }

    Group { Anchor: (Width: 10); }

    Button #Slot7 {
      Anchor: (Width: 110, Height: 62);
      Style: @SlotStyle;
      LayoutMode: Top;
      Padding: (Full: 4);

      ItemIcon #Slot7Icon {
        Anchor: (Width: 32, Height: 32);
      }

      Label #Slot7Text {
        Text: "";
        Anchor: (Height: 20);
        Style: @SlotLabelStyle;
      }
    }

    Group { Anchor: (Width: 10); }

    Button #Slot8 {
      Anchor: (Width: 110, Height: 62);
      Style: @SlotStyle;
      LayoutMode: Top;
      Padding: (Full: 4);

      ItemIcon #Slot8Icon {
        Anchor: (Width: 32, Height: 32);
      }

      Label #Slot8Text {
        Text: "";
        Anchor: (Height: 20);
        Style: @SlotLabelStyle;
      }
    }
  }

  Group { FlexWeight: 1; }

  Group {
    LayoutMode: Center;
    Anchor: (Height: 44);

    TextButton #CloseButton {
      Text: "CLOSE";
      Anchor: (Width: 110, Height: 38);
      Style: @CloseButtonStyle;
    }
  }

  Group { Anchor: (Height: 6); }

  Label {
    Text: "Press ESC to close";
    Anchor: (Height: 16);
    Style: (FontSize: 11, TextColor: #4a5568, HorizontalAlignment: Center);
  }
}
