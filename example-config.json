  "pages": {
    "rules": {
      "title": "Server Rules",
      "lines": [
        "&bWelcome to HTSkyBlock, &f{player}&b!",
        "",
        "&ePlease follow these rules:",
        "",
        "&f1. &7Be respectful to all players",
        "&f2. &7No griefing or stealing",
        "&f3. &7No cheating, hacking, or exploits",
        "&f4. &7Keep chat family-friendly",
        "&f5. &7No spamming or advertising",
        "&f6. &7Listen to staff members",
        "&f7. &7No real-money trading",
        "&f8. &7Report bugs, don't abuse them",
        "",
        "&cBreaking rules may result in a ban."
      ]
    },
    "welcome": {
      "title": "Welcome to HTSkyBlock!",
      "lines": [
        "&bHello &f{player}&b, welcome!",
        "",
        "&eGetting Started:",
        "&7- Use &f/island create &7to make your island",
        "&7- Use &f/island home &7to go to your island",
        "&7- Use &f/shop &7to buy and sell items",
        "&7- Use &f/bal &7to check your balance",
        "",
        "&eProgression:",
        "&7- Use &f/lvl gui &7to view your skills",
        "&7- Use &f/island top &7to see the leaderboard",
        "&7- Use &f/lootbox inventory &7for your keys",
        "",
        "&aNeed help? Use &f/help &aor ask staff!",
        "",
        "&dEnjoy your SkyBlock adventure!"
      ]
    }
